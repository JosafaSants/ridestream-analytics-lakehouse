# Copie este arquivo para .env e preencha com seus valores
# O arquivo .env nunca deve ser commitado no Git

# Endereço do Kafka — localmente via Docker, na AWS use o endereço do MSK
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Nome do tópico onde os eventos de corridas serão publicados
KAFKA_TOPIC_RIDES=ride-events